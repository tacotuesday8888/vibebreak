{
  "name": "vibebreak-arcade",
  "version": "0.2.0",
  "description": "A chaotic-cozy terminal break arcade for tiny coding-session resets.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vibebreak-arcade": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "bun:daily": "bun run src/index.tsx daily",
    "bun:start": "bun run src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "prepare": "npm run build",
    "start": "tsx src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arcade",
    "break",
    "cli",
    "game",
    "ink",
    "react",
    "terminal",
    "typescript"
  ],
  "author": "langqi <langqizhao@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/tacotuesday8888/vibebreak#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tacotuesday8888/vibebreak.git"
  },
  "bugs": {
    "url": "https://github.com/tacotuesday8888/vibebreak/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ink": "^7.0.2",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
